# Minimal CIF fixture for Z-estimation tests
# Urea CO(NH2)2 -- P-42_1m, organic on special position, Z=2, Z'=1/4, formula_derived NOT expected
data_urea
_chemical_formula_sum 'C H4 N2 O'
_cell_formula_units_Z 2
_cell_length_a 5.565
_cell_length_b 5.565
_cell_length_c 4.684
_cell_angle_alpha 90.0
_cell_angle_beta 90.0
_cell_angle_gamma 90.0
_symmetry_space_group_name_H-M 'P -4 2_1 m'

